/* ============================================================
   COMPARE MODE — two fully independent side-by-side 3D viewers
   Overlays the main canvas region; sits below the instruction
   banner (z 7) and the right-side controls/odontogram (z 8).
   ============================================================ */
.compare-view {
  position: absolute;
  /* Sit below the instruction banner so the per-tooth titles are visible, and
     reserve a generous bottom band so the (now larger) odontogram has room
     beneath the viewers without any collision. The viewers end up roughly
     half-height, matching the reference layout. */
  top: clamp(84px, 9vh, 112px);
  left: clamp(8px, 0.9vw, 12px);
  bottom: clamp(250px, 30vh, 330px);
  /* Reserve the right-side control column (Visibility / Occlusion / Jaw) plus a
     safe gap, so the canvases never sit under it. */
  right: clamp(300px, 23vw, 384px);
  z-index: 5;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 1px minmax(0, 1fr);
  border-radius: 26px;
  overflow: hidden;
  background: var(--canvas-surface, rgb(18, 19, 22));
  isolation: isolate;
  box-sizing: border-box;
}

.compare-view[hidden] {
  display: none;
}

.compare-canvas-panel {
  position: relative;
  min-width: 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.compare-title {
  margin: 0;
  padding: clamp(14px, 1.8vw, 26px) 12px clamp(6px, 0.8vw, 12px);
  text-align: center;
  color: rgba(255, 255, 255, 0.92);
  font-weight: 600;
  font-size: clamp(1.05rem, 0.9rem + 0.6vw, 1.5rem);
  letter-spacing: 0.01em;
  pointer-events: none;
}

.compare-canvas-wrap {
  position: relative;
  flex: 1 1 auto;
  min-height: 0;
}

.compare-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  display: block;
  border: 0;
  outline: none;
  background: transparent;
  touch-action: none;
}

.compare-divider {
  width: 1px;
  background: rgba(255, 255, 255, 0.15);
}

/* Dark, controlled error state for a single compare canvas — shown instead of
   ever letting the area go white if a tooth can't be displayed. */
.compare-error {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: none;            /* toggled to flex by JS */
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 24px;
  color: rgba(255, 255, 255, 0.78);
  font-size: clamp(0.85rem, 0.78rem + 0.3vw, 1rem);
  line-height: 1.4;
  background: var(--canvas-surface, rgb(18, 19, 22));
  border-radius: inherit;
  pointer-events: none;
}

/* During Compare mode, tuck the odontogram into the reserved right column so it
   no longer overhangs the canvases (matches the target). Desktop/laptop only —
   below 900px the controls already stack under the viewers. */
@media (min-width: 901px) {
  /* In compare mode the odontogram becomes the primary control: keep it large
     and bottom-right (it sits below the half-height viewers, so the extra width
     no longer collides with them). */
  .scene-area.is-comparing .floating-odontogram {
    width: clamp(440px, 36vw, 620px);
    max-width: min(72vw, 660px);
    align-self: flex-end;
  }

  .scene-area.is-comparing .floating-odontogram .odo-systems {
    flex: 0 0 clamp(108px, 8.5vw, 140px);
  }

  .scene-area.is-comparing .floating-odontogram .odo-systems-title {
    margin-bottom: 7px;
    font-size: 0.86rem;
  }

  .scene-area.is-comparing .floating-odontogram .odo-radio {
    font-size: 0.8rem;
  }
}

/* Laptop / mid-width desktop: tighten the reserved column a touch. */
@media (min-width: 901px) and (max-width: 1280px) {
  .compare-view {
    right: clamp(260px, 23vw, 330px);
  }

  .compare-title {
    font-size: clamp(0.9rem, 0.8rem + 0.5vw, 1.2rem);
    padding: clamp(10px, 1.4vw, 18px) 10px clamp(4px, 0.6vw, 8px);
  }
}

/* Narrow / mobile: stack the two viewers vertically, no horizontal scroll. */
@media (max-width: 900px) {
  .compare-view {
    position: relative;
    top: auto;
    left: auto;
    bottom: auto;
    right: auto;
    grid-template-columns: 1fr;
    grid-template-rows: auto 1px auto;
    min-height: 0;
    border-radius: 20px;
  }

  .compare-canvas-wrap {
    height: 44vh;
    max-height: 44vh;
  }

  .compare-divider {
    width: auto;
    height: 1px;
  }

  .compare-title {
    padding: clamp(8px, 2.4vw, 14px) 10px clamp(4px, 1.4vw, 8px);
  }
}

@media (max-width: 820px) {
  .compare-view {
    border-radius: 18px;
  }
}

/* ============================================================
   Mobile-only chrome (hamburger button + drawer). Hidden by
   default on every screen size; mobile.css turns them on only
   at <=600px. Defined here (outside any media query) so desktop
   and tablet never render these new elements.
   ============================================================ */
.mobile-menu-btn,
.mobile-drawer,
.mobile-drawer-scrim {
  display: none;
}
