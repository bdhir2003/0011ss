:root {
  --bg: #161616;
  --header: rgba(18, 18, 18, 0.94);
  --panel: linear-gradient(180deg, rgba(46, 46, 46, 0.56), rgba(24, 24, 24, 0.44));
  --panel-soft: linear-gradient(180deg, rgba(44, 44, 44, 0.52), rgba(22, 22, 22, 0.4));
  --panel-inset: rgba(255, 255, 255, 0.035);
  --border: rgba(255, 255, 255, 0.14);
  --border-strong: rgba(255, 255, 255, 0.18);
  --text: rgba(255, 255, 255, 0.92);
  --label: rgba(255, 255, 255, 0.72);
  --muted: rgba(255, 255, 255, 0.55);
  --accent: #d9163a;
  --accent-dark: #a7102b;
  --accent-soft: #f12f52;
  --cyan: rgba(122, 214, 233, 0.88);
  --white-pill: #f4f2ef;
  --shadow: 0 10px 30px rgba(0, 0, 0, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  --shadow-soft: 0 18px 38px rgba(0, 0, 0, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.025);
  --radius: 22px;
  --canvas-surface: linear-gradient(180deg, rgba(24, 24, 25, 0.96), rgba(14, 15, 17, 0.98));
  --shell-gap: clamp(12px, 1.4vw, 20px);
  --shell-pad-x: clamp(16px, 2vw, 28px);
  --shell-pad-y: clamp(14px, 1.8vw, 24px);
  --canvas-height: clamp(620px, 74vh, 860px);
  --panel-pad: clamp(16px, 1.4vw, 22px);
  --control-font: clamp(0.82rem, 0.72rem + 0.18vw, 0.95rem);
}

* {
  box-sizing: border-box;
}

html,
body {
  margin: 0;
  min-height: 100%;
  background:
    radial-gradient(circle at top left, rgba(217, 22, 58, 0.08), transparent 24%),
    radial-gradient(circle at 82% 18%, rgba(255, 255, 255, 0.025), transparent 18%),
    linear-gradient(180deg, #181818 0%, #141414 100%);
  color: var(--text);
  font-family: "Manrope", sans-serif;
  overflow-x: hidden;
}

body {
  min-height: 100vh;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
label {
  font: inherit;
}

button {
  cursor: pointer;
}

.app-shell {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow-x: clip;
}

.app-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24px;
  min-height: 78px;
  padding: 16px 32px;
  background:
    linear-gradient(180deg, rgba(22, 22, 22, 0.98), rgba(17, 17, 17, 0.95));
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 10px 26px rgba(0, 0, 0, 0.22);
  position: sticky;
  top: 0;
  z-index: 20;
}

.brand {
  display: flex;
  align-items: center;
  gap: 18px;
  flex-shrink: 0;
}

.brand img {
  width: 92px;
  height: auto;
  object-fit: contain;
}

.brand h1 {
  margin: 0;
  font-size: 2.15rem;
  font-weight: 500;
  letter-spacing: -0.04em;
  text-transform: none;
  color: rgba(255, 255, 255, 0.96);
}

.search-shell {
  width: min(460px, 100%);
  min-width: 0;
  margin-left: auto;
}

.search-field {
  position: relative;
  display: flex;
  align-items: center;
  height: 44px;
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 14px;
  background: linear-gradient(180deg, rgba(42, 42, 42, 0.72), rgba(28, 28, 28, 0.84));
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
  overflow: hidden;
}

#searchBox {
  flex: 1;
  height: 100%;
  border: 0;
  outline: 0;
  background: transparent;
  color: var(--text);
  padding: 0 14px 0 16px;
  font-size: 0.92rem;
}

#searchBox::placeholder {
  color: rgba(255, 255, 255, 0.44);
}

#searchBtn,
#closeSearchBtn {
  border: 0;
  background: transparent;
  color: var(--label);
  height: 100%;
  padding: 0 14px;
}

#searchBtn {
  border-left: 1px solid rgba(255, 255, 255, 0.08);
  font-size: 0.86rem;
}

#closeSearchBtn {
  padding-right: 16px;
  font-size: 1.4rem;
  line-height: 1;
}

#searchBtn:hover,
#closeSearchBtn:hover {
  color: var(--text);
}

#searchResultsDiv {
  position: fixed;
  top: 88px;
  left: 0;
  z-index: 25;
  width: min(460px, calc(100vw - 32px));
  display: none;
  background: linear-gradient(180deg, rgba(40, 40, 40, 0.98), rgba(28, 28, 28, 0.98));
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 16px;
  box-shadow: var(--shadow);
  overflow: hidden;
}

#resultsList {
  list-style: none;
  margin: 0;
  padding: 8px 0;
  max-height: 60vh;
  overflow-y: auto;
}

.result-item {
  margin: 0;
  padding: 12px 16px;
  color: var(--text);
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.result-item:last-child {
  border-bottom: 0;
}

.result-item:hover {
  background: rgba(217, 22, 58, 0.18);
  cursor: pointer;
}

.app-main {
  display: grid;
  grid-template-columns: minmax(260px, clamp(280px, 22vw, 390px)) minmax(0, 1fr);
  gap: var(--shell-gap);
  padding: var(--shell-pad-y) var(--shell-pad-x) clamp(28px, 4vh, 52px);
  align-items: stretch;
  flex: 1;
  min-height: calc(100vh - 132px);
}

.left-column {
  display: flex;
  flex-direction: column;
  gap: clamp(10px, 1.2vw, 18px);
  min-width: 0;
  min-height: 100%;
}

.center-column {
  min-width: 0;
  min-height: 100%;
  display: flex;
}

.panel {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  overflow: hidden;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: var(--panel-pad) var(--panel-pad) 0;
}

.panel-header.compact {
  padding-top: 14px;
}

.panel-header h2 {
  margin: 0;
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--text);
}

.info-panel {
  min-height: clamp(500px, 50vh, 600px);
  padding-bottom: 26px;
  display: flex;
  flex-direction: column;
  /* Cleaner, more solid dark card (reference style) while staying on-theme. */
  background: linear-gradient(180deg, rgba(42, 42, 42, 0.82), rgba(22, 22, 22, 0.78));
}

/* Larger, cleaner "Information" title — scoped to the info card only so other
   panel headers keep their size. clamp() keeps it responsive on its own. */
.info-panel .panel-header {
  padding-top: 26px;
}

.info-panel .panel-header h2 {
  font-size: clamp(1.2rem, 0.95rem + 1.1vw, 1.7rem);
  font-weight: 700;
  letter-spacing: -0.02em;
}

.tooth-meta {
  padding: 16px var(--panel-pad) 0;
  color: var(--muted);
  font-size: 0.82rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.info-scroll {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 18px;
  padding: 18px var(--panel-pad) 0;
}

#info,
#compareLeft,
#compareRight {
  min-height: 0;
  color: var(--label);
  font-size: 0.95rem;
  line-height: 1.7;
  white-space: normal;
  overflow-wrap: anywhere;
}

#info {
  flex: 1;
  /* The selected-tooth name is the main dynamic content: make it prominent
     and easy to read. Self-responsive via clamp(). */
  color: var(--text);
  font-size: clamp(0.98rem, 0.9rem + 0.4vw, 1.12rem);
  line-height: 1.85;
}

.compare-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

/* Keep the compare/isolate detail boxes in the DOM for functionality, but
   don't show empty placeholder boxes — keeps the card clean like the
   reference. They reappear automatically once filled with real data. */
#compareLeft:empty,
#compareRight:empty {
  display: none;
}

#compareLeft,
#compareRight {
  min-height: 88px;
  padding: 14px;
  border-radius: 14px;
  background: linear-gradient(180deg, rgba(54, 54, 54, 0.18), rgba(28, 28, 28, 0.14));
  border: 1px solid rgba(255, 255, 255, 0.07);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
}

.info-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  padding: 20px var(--panel-pad) 0;
  align-items: center;
}

.compare-action {
  min-width: 0;
}

.pill-input,
.toggle-input,
.utility-input {
  position: absolute;
  opacity: 0;
  pointer-events: none;
}

.pill-button,
.secondary-action,
.text-link-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48px;
  border-radius: 999px;
  border: 1px solid transparent;
  font-size: 0.94rem;
  font-weight: 700;
  transition: 0.2s ease;
}

.compare-pill,
.light-pill {
  width: 100%;
}

.compare-pill,
.light-pill {
  background: var(--white-pill);
  color: #252525;
}

#compareCheckbox:checked + .compare-pill {
  background: var(--accent);
  color: white;
}

/* Isolate active state: JS adds .is-active when isolation is on, turning the
   button the app red (matches the Compare active state). Compare and Isolate
   are mutually exclusive in the app logic, so only one is ever red. */
.light-pill.is-active {
  background: var(--accent);
  color: #fff;
}

.light-pill.is-active:hover {
  background: var(--accent-soft);
}

#compareCheckbox:disabled + .compare-pill,
#compareCheckbox[style*="pointer-events: none"] + .compare-pill {
  opacity: 0.5;
}

.secondary-action {
  width: calc(100% - (var(--panel-pad) * 2));
  margin: 14px var(--panel-pad) 0;
  background: transparent;
  color: rgba(255, 255, 255, 0.86);
  border-color: rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  min-height: 44px;
  text-transform: none;
  background: linear-gradient(180deg, rgba(50, 50, 50, 0.12), rgba(24, 24, 24, 0.08));
}

.secondary-action:hover,
.light-pill:hover,
.compare-pill:hover,
.text-link-button:hover {
  transform: translateY(-1px);
}

.xray-panel {
  min-height: clamp(296px, 32vh, 336px);
  padding-bottom: 20px;
}

.text-link-button {
  min-height: auto;
  padding: 0;
  border: 0;
  background: transparent;
  color: #d7d7d7;
  font-size: 0.82rem;
  font-weight: 600;
}

.xray-frame {
  height: clamp(220px, 28vh, 250px);
  margin: 18px var(--panel-pad) 0;
  padding: 14px;
  border-radius: 18px;
  background:
    radial-gradient(circle at top, rgba(255, 255, 255, 0.06), transparent 38%),
    linear-gradient(180deg, rgba(62, 62, 62, 0.18), rgba(18, 18, 18, 0.12));
  border: 1px solid rgba(255, 255, 255, 0.07);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
}

#xrayImage,
#xrayModalImage {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  filter: contrast(1.03);
}

.scene-area {
  position: relative;
  width: 100%;
  min-width: 0;
  min-height: max(var(--canvas-height), calc(100vh - 188px));
  height: max(var(--canvas-height), calc(100vh - 188px));
  border-radius: 30px;
  padding: clamp(8px, 0.9vw, 12px);
  background: var(--canvas-surface);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: var(--shadow-soft), inset 0 1px 0 rgba(255, 255, 255, 0.025);
  overflow: visible;
  isolation: isolate;
}

#threejs-canvas {
  display: block;
  width: 100%;
  min-width: 0;
  height: 100%;
  min-height: max(var(--canvas-height), calc(100vh - 188px));
  border-radius: 26px;
  background: transparent;
}

#hud {
  position: absolute;
  left: 18px;
  top: 18px;
  z-index: 6;
  pointer-events: none;
  color: white;
}

.message-layer {
  position: absolute;
  /* top / right / bottom / left — right reservation matches the overlay-stack
     width (min(23vw,306px) + ~22px right offset + safe gap) so the banner
     always stops clearly before the Visibility / Occlusion / Jaw cards. */
  inset: clamp(12px, 1.2vw, 16px) clamp(260px, 24vw + 40px, 420px) auto clamp(12px, 1.2vw, 18px);
  z-index: 7;
  pointer-events: none;
}

.message-box {
  min-height: 78px;
  border-radius: 18px;
  border: 1px solid var(--cyan);
  background: linear-gradient(180deg, rgba(48, 50, 50, 0.58), rgba(30, 32, 32, 0.42));
  padding: 0 22px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  pointer-events: auto;
  box-shadow: var(--shadow);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.message-box span {
  color: rgba(255, 255, 255, 0.88);
  font-size: clamp(0.88rem, 0.8rem + 0.2vw, 0.98rem);
}

.message-close {
  width: 36px;
  height: 36px;
  border: 0;
  background: transparent;
  color: #f2f2f2;
  font-size: 1.9rem;
  line-height: 1;
  padding: 0;
}

/* --- Overlay icon row: Help & Reset buttons above Visibility card --- */
.overlay-icon-row {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  pointer-events: auto;
}

.overlay-icon-btn {
  width: clamp(36px, 2.6vw, 46px);
  height: clamp(36px, 2.6vw, 46px);
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: linear-gradient(180deg, rgba(50, 50, 50, 0.5), rgba(24, 24, 24, 0.35));
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.04);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  transition: background 0.2s, border-color 0.2s, transform 0.15s;
}

.overlay-icon-btn:hover {
  background: linear-gradient(180deg, rgba(70, 70, 70, 0.6), rgba(40, 40, 40, 0.45));
  border-color: rgba(255, 255, 255, 0.22);
  transform: scale(1.08);
}

.overlay-icon-btn:active {
  transform: scale(0.96);
}

.overlay-icon-img {
  width: 60%;
  height: 60%;
  object-fit: contain;
  filter: brightness(0.95);
}

/* --- Help modal overlay --- */
.help-modal-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.5);
  pointer-events: auto;
}

.help-modal {
  position: relative;
  width: 90%;
  max-width: 750px;
  background: rgba(35, 35, 35, 0.82);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.22);
  border-radius: 18px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
  padding: 36px 40px 40px;
  color: #fff;
}

.help-close {
  position: absolute;
  top: 16px;
  right: 22px;
  background: none;
  border: none;
  color: #fff;
  font-size: 2rem;
  cursor: pointer;
  padding: 0;
  line-height: 1;
  transition: opacity 0.15s;
}

.help-close:hover {
  opacity: 0.7;
}

.help-modal h2 {
  margin-top: 0;
  margin-bottom: 30px;
  font-size: 1.6rem;
  font-weight: 500;
  border-bottom: none;
}

.help-content {
  display: flex;
  justify-content: space-between;
  gap: 20px;
}

.help-item {
  flex: 1;
  text-align: center;
}

.help-item-img {
  width: 100%;
  max-width: 220px;
  height: auto;
  object-fit: contain;
  border-radius: 8px;
}

@media (max-width: 600px) {
  .help-content {
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .help-item-img {
    max-width: 80%;
  }

  .help-modal {
    padding: 24px 20px 28px;
  }

  .help-modal h2 {
    font-size: 1.3rem;
    margin-bottom: 20px;
  }
}

.scene-overlay-stack {
  position: absolute;
  top: clamp(14px, 1.5vw, 20px);
  right: clamp(14px, 1.5vw, 22px);
  bottom: clamp(18px, 1.8vw, 24px);
  z-index: 8;
  width: min(23vw, 306px);
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: space-between;
  gap: clamp(9px, 0.8vw, 12px);
  pointer-events: none;
}

.scene-overlay-stack > * {
  pointer-events: auto;
}

.floating-controls {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: clamp(9px, 0.8vw, 12px);
}

.floating-controls .control-panel {
  min-height: auto;
  width: clamp(180px, 13vw, 220px);
  align-self: flex-end;
}

.floating-controls .visibility-panel,
.floating-controls .occlusion-panel,
.floating-controls .jaw-panel {
  min-height: auto;
}

.floating-controls .toggle-list {
  padding: 7px 11px 10px;
}

.floating-controls .toggle-row {
  min-height: 22px;
}

.floating-controls .jaw-toggle-row {
  padding: 3px 11px 10px;
}

.utility-icon {
  width: clamp(32px, 2.2vw, 42px);
  height: clamp(32px, 2.2vw, 42px);
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: linear-gradient(180deg, rgba(50, 50, 50, 0.4), rgba(24, 24, 24, 0.28));
  color: rgba(255, 255, 255, 0.92);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.utility-toggle {
  cursor: pointer;
  text-decoration: none;
}

#jawViewCheckbox:checked + .utility-toggle {
  background: var(--accent);
  border-color: rgba(255, 255, 255, 0.14);
}

#loadingDiv {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 5;
  width: 80px;
  height: 80px;
}

.lds-spinner div {
  transform-origin: 40px 40px;
  animation: lds-spinner 1.2s linear infinite;
}

.lds-spinner div::after {
  content: " ";
  display: block;
  position: absolute;
  top: 3px;
  left: 37px;
  width: 6px;
  height: 18px;
  border-radius: 20%;
  background: white;
}

.lds-spinner div:nth-child(1) { transform: rotate(0deg); animation-delay: -1.1s; }
.lds-spinner div:nth-child(2) { transform: rotate(30deg); animation-delay: -1s; }
.lds-spinner div:nth-child(3) { transform: rotate(60deg); animation-delay: -0.9s; }
.lds-spinner div:nth-child(4) { transform: rotate(90deg); animation-delay: -0.8s; }
.lds-spinner div:nth-child(5) { transform: rotate(120deg); animation-delay: -0.7s; }
.lds-spinner div:nth-child(6) { transform: rotate(150deg); animation-delay: -0.6s; }
.lds-spinner div:nth-child(7) { transform: rotate(180deg); animation-delay: -0.5s; }
.lds-spinner div:nth-child(8) { transform: rotate(210deg); animation-delay: -0.4s; }
.lds-spinner div:nth-child(9) { transform: rotate(240deg); animation-delay: -0.3s; }
.lds-spinner div:nth-child(10) { transform: rotate(270deg); animation-delay: -0.2s; }
.lds-spinner div:nth-child(11) { transform: rotate(300deg); animation-delay: -0.1s; }
.lds-spinner div:nth-child(12) { transform: rotate(330deg); animation-delay: 0s; }

@keyframes lds-spinner {
  0% { opacity: 1; }
  100% { opacity: 0; }
}

/* =====================================================================
   Combined odontogram + numbering-system card (bottom-right of scene).
   Real, clickable odontogram built from the actual odontogram_*.png art
   plus a hotspot/highlight layer injected by dentistry_js.js.
   ===================================================================== */
/* In-flow card living in the right column, below the Jaw position panel
   (no longer an absolute overlay on the canvas). */
.odontogram-card {
  position: relative;
  width: 100%;
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px;
  border-radius: 20px;
  background: var(--panel);
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  min-width: 0;
  margin-top: auto;
}

.floating-odontogram {
  margin-top: auto;
  /* Right-anchored so the card can grow leftward over the scene instead of
     being pinned to the narrow control stack. The previous max-width:100%
     capped it to the ~330px stack, which is why the odontogram looked tiny. */
  align-self: flex-end;
  width: clamp(520px, 36vw, 680px);
  max-width: min(72vw, 700px);
  padding: 12px 16px;
  gap: 16px;
  border-radius: 18px;
  z-index: 30;
}

/* Let the tooth diagram take the lion's share of the card width. */
.floating-odontogram .odo-figure {
  flex: 1 1 auto;
}

.floating-odontogram .odo-systems {
  flex: 0 0 clamp(118px, 8.5vw, 146px);
  gap: 6px;
}

