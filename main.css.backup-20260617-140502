/* Dark chart inset (matches the dark card). The dark-theme odontogram art is
   light line-art on transparent, so it reads cleanly here. The box aspect ratio
   matches the art exactly (3472x1657), so object-fit leaves no letterboxing and
   the hotspot layer maps pixel-accurately. */
.odo-stage {
  position: relative;
  width: 100%;
  max-width: 100%;
  aspect-ratio: 3472 / 1657;
  border-radius: 12px;
  background: linear-gradient(180deg, rgba(54, 54, 54, 0.14), rgba(24, 24, 24, 0.08));
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  overflow: hidden;
}

.odo-base {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
  user-select: none;
  -webkit-user-drag: none;
  pointer-events: none;
  /* Desaturate all color (kills red numbers) then brighten so the former-red
     text becomes white.  White teeth are already at max, so they stay white.
     Black outlines get a mild lift to softer gray. */
  filter: saturate(0) brightness(2);
}

/* The hotspot/highlight layer tracks the <img> box exactly */
.odo-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.odo-hotspot {
  position: absolute;
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  border-radius: 5px;
  cursor: pointer;
  pointer-events: auto;
  transition: background 0.15s ease;
}

.odo-hotspot:hover {
  background: rgba(0, 150, 170, 0.22);
}

.odo-hotspot:focus-visible {
  outline: 2px solid var(--cyan);
  outline-offset: 1px;
}

.odo-highlight {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.12s ease;
}

.odo-highlight.is-active {
  opacity: 1;
}

