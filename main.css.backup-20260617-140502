  border-color: #fff;
}

.odo-radio input:checked + .odo-dot::after {
  content: "";
  position: absolute;
  inset: 3px;
  border-radius: 50%;
  background: #fff;
}

.odo-radio:hover .odo-dot {
  border-color: rgba(255, 255, 255, 0.95);
